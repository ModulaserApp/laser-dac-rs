#!/bin/sh
. "$HOME/.cargo/env" 2>/dev/null

# Get staged .rs files
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$')
if [ -n "$STAGED" ]; then
    cargo fmt
    echo "$STAGED" | xargs git add
fi

# Run validation on any Rust changes. Use --all-features so feature-gated code
# (e.g. the `receiver`/`testutils` integration tests) is compiled locally just
# like CI does — otherwise a plain default-feature check silently skips it and
# the breakage only surfaces on CI.
if [ -n "$STAGED" ]; then
    echo "Running cargo check..."
    cargo check --all-features --all-targets || exit 1

    echo "Running cargo clippy..."
    cargo clippy --all-features --all-targets -- -D warnings || exit 1
fi
